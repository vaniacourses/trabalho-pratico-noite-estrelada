// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum EstadoLeitor {
  INCOMPLETO
  REGULAR
  EM_PUNICAO
  BANIDO
}

enum EstadoExemplar {
  DISPONIVEL
  EMPRESTADO
  AFASTADO
  RESERVADO
}

enum EstadoEmprestimo {
  PENDENTE
  CORRENTE
  ATRASADO
  FINALIZADO
  REJEITADO
}

enum EstadoReserva {
  EM_ESPERA
  BLOQUEANTE
  FINALIZADA
}

enum TipoDeMidia {
  PUBLICACAO
  DVD
  CD
}

enum TipoUsuario {
  LEITOR
  ATENDENTE
  GERENTE
}

// Models
model Leitor {
  id               String       @id @default(cuid())
  nome             String
  cpf              String?      @unique
  dataDeNascimento DateTime?
  email            String?
  senha            String
  tipo             TipoUsuario  @default(LEITOR)
  estado           EstadoLeitor @default(INCOMPLETO)
  dataCriacao      DateTime     @default(now())
  dataAtualizacao  DateTime     @updatedAt

  emprestimos      Emprestimo[]
  reservas         Reserva[]

  @@map("usuarios")
}

model Midia {
  id          String      @id @default(cuid())
  tipo        TipoDeMidia @default(PUBLICACAO)
  titulo      String
  dataCriacao DateTime    @default(now())

  exemplares Exemplar[]
  reservas   Reserva[]
  dados      Json

  @@map("midias")
}

model Exemplar {
  id              String         @id @default(cuid())
  idMidia         String
  estado          EstadoExemplar @default(DISPONIVEL)
  dataCriacao     DateTime       @default(now())
  dataAtualizacao DateTime       @updatedAt

  midia       Midia        @relation(fields: [idMidia], references: [id], onDelete: Cascade)
  emprestimos Emprestimo[]

  @@index([idMidia])
  @@map("exemplares")
}

model Emprestimo {
  id              String           @id @default(cuid())
  idLeitor        String
  idExemplar      String
  dataInicio      DateTime         @default(now())
  dataExpiracao   DateTime
  dataFinalizacao DateTime?
  estado          EstadoEmprestimo @default(CORRENTE)
  dataCriacao     DateTime         @default(now())
  dataAtualizacao DateTime         @updatedAt

  leitor   Leitor   @relation(fields: [idLeitor], references: [id], onDelete: Cascade)
  exemplar Exemplar @relation(fields: [idExemplar], references: [id], onDelete: Cascade)

  @@map("emprestimos")
  @@index([idLeitor])
  @@index([idExemplar])
}

model Reserva {
  id              String        @id @default(cuid())
  idLeitor        String
  idMidia         String
  dataMidia       DateTime
  estado          EstadoReserva @default(EM_ESPERA)
  dataCriacao     DateTime      @default(now())
  dataAtualizacao DateTime      @updatedAt

  leitor Leitor @relation(fields: [idLeitor], references: [id], onDelete: Cascade)
  midia  Midia  @relation(fields: [idMidia], references: [id], onDelete: Cascade)

  @@index([idLeitor])
  @@index([idMidia])
  @@map("reservas")
}